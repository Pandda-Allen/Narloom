# Flask 应用配置
FLASK_DEBUG=True
FLASK_ENV=development
SECRET_KEY=your-secret-key-here
PORT=5000

# OpenAI 配置（可选）
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# AI 处理参数
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.7

# 阿里云 DashScope（通义千问）配置
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_DEFAULT_MODEL=qwen3.5-plus

# OpenRouter 配置（可选）
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# MySQL 配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DB=narloom
MYSQL_CHARSET=utf8mb4

# MongoDB 配置
MONGO_URI=mongodb://localhost:27017/
MONGO_DB=narloom
MONGO_ASSET_DATA_COLLECTION=asset_data
MONGO_WORK_DETAILS_COLLECTION=work_details

# 阿里云 OSS 配置（Anime Tool）
ALIYUN_OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
ALIYUN_OSS_ACCESS_KEY_ID=your-access-key-id
ALIYUN_OSS_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_OSS_BUCKET_NAME=narloom001
ALIYUN_OSS_CDN_DOMAIN=your-cdn-domain.com

# JWT 配置
JWT_SECRET_KEY=your-jwt-secret-key-minimum-32-chars
JWT_ACCESS_TOKEN_EXPIRES=30
JWT_REFRESH_TOKEN_EXPIRES=7
JWT_ALGORITHM=HS256
JWT_ISSUER=narloom-api
JWT_AUDIENCE=narloom-client

# 微信 OAuth2.0 配置
WECHAT_OAUTH_APP_ID=wx_xxxxx
WECHAT_OAUTH_APP_SECRET=your-wechat-app-secret
WECHAT_OAUTH_REDIRECT_URI=http://localhost:5000/user/oauth/wechat/callback

# QQ OAuth2.0 配置
QQ_OAUTH_APP_ID=1xxxxx
QQ_OAUTH_APP_KEY=your-qq-app-key
QQ_OAUTH_REDIRECT_URI=http://localhost:5000/user/oauth/qq/callback

# CORS 配置
CORS_ORIGINS=*
